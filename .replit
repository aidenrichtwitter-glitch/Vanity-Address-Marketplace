modules = ["python-3.11", "nodejs-20", "rust-stable"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["dbus", "fontconfig", "freetype", "libGL", "libsodium", "libxcrypt", "libxkbcommon", "mesa_drivers", "ocl-icd", "opencl-headers", "qt6.qtbase", "xcb-util-cursor", "xorg.libX11", "xorg.libXcursor", "xorg.libXext", "xorg.libXfixes", "xorg.libXi", "xorg.libXrandr", "xorg.libXrender", "xorg.libxcb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web_app.py"
waitForPort = 5000

[[ports]]
localPort = 3092
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80
