modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libsodium", "libxcrypt", "mesa_drivers", "ocl-icd", "opencl-headers", "libGL", "libxkbcommon", "xorg.libX11", "xorg.libXcursor", "xorg.libXi", "xorg.libXrandr", "fontconfig", "freetype", "qt6.qtbase", "xorg.libxcb", "xorg.libXext", "xorg.libXfixes", "xorg.libXrender", "dbus"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python gui.py"
