modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libsodium", "mesa_drivers", "ocl-icd", "opencl-headers"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py --no-gpu --gpu-batch-size 1024 --threads 2 --min-word-length 4"

[workflows.workflow.metadata]
outputType = "console"
